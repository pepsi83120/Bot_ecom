# ============================================================
#  Variables d'environnement — Railway
#  Copie ces clés dans ton projet Railway > Variables
# ============================================================

# Bot principal (e-commerce, déjà existant)
ECOM_BOT_TOKEN=ton_token_bot_ecom

# Bot admin (NOUVEAU — crée un 2e bot sur @BotFather)
ADMIN_BOT_TOKEN=ton_token_bot_admin

# Ton ID Telegram (obtiens-le avec /myid sur ton bot)
ADMIN_ID=123456789

# Groq API
GROQ_API_KEY=gsk_...

# Hugging Face (optionnel, pour les images)
HF_API_KEY=hf_...

# Secret webhook Beacons (optionnel mais recommandé)
# Met une chaîne aléatoire ici, puis configure-la dans Beacons > Webhooks > Secret
BEACONS_SECRET=une_chaine_aleatoire_secrete

# Port Flask (Railway le définit automatiquement)
PORT=5000
